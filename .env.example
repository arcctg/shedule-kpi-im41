# Telegram Bot Token (required)
BOT_TOKEN=your_telegram_bot_token_here

# Webhook URL (optional - if not set, polling mode will be used)
# Example: https://yourdomain.com
WEBHOOK_URL=

# Webhook secret token (optional but strongly recommended in production)
# Must match the secret configured in Telegram's setWebhook call.
# If set, Railway/Express will reject requests without a valid X-Telegram-Bot-Api-Secret-Token header.
WEBHOOK_SECRET=

# Server port (default: 3000)
PORT=3000

# KPI API Group ID (default: 4318 for IM-41)
GROUP_ID=4318

# Cache TTL in seconds (default: 300)
CACHE_TTL=300

# Log level (default: info)
LOG_LEVEL=info

# Database path (default: ./data/links.db)
DB_PATH=./data/links.db

# Admin access for /setlink and /deletelink
# Comma-separated Telegram user IDs (numbers)
ADMIN_IDS=123456789,987654321
# Comma-separated Telegram usernames (without @, case-insensitive)
ADMIN_USERNAMES=username1,username2
